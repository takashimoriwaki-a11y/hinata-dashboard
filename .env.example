# ===================================================================
# ひなた訪問看護ダッシュボード 環境変数テンプレート
# ===================================================================
#
# Railway の「Variables」タブにこれらを設定します。
# このファイル自体はGitHubにコミットされていますが、実値は絶対にコミットしないでください。
# （.env ファイルは .gitignore で除外されているので、このテンプレートをコピーして .env を作成）
#
# ===================================================================

# -------------------------------------------------------------------
# 必須：データベース接続
# -------------------------------------------------------------------
# Railway MySQL サービスを作成すると自動発行されます。
# Railway上では、同じプロジェクト内のMySQLサービスから ${{ MySQL.MYSQL_URL }} を参照するのが推奨。
DATABASE_URL=mysql://user:password@host:port/dbname

# -------------------------------------------------------------------
# 必須：セッション Cookie 署名用 シークレット
# -------------------------------------------------------------------
# 生成方法（ターミナルで）: openssl rand -hex 32
# Railway管理画面のVariables追加時、「Generate Variable」ボタンでもOK
JWT_SECRET=ここに64文字程度のランダム文字列を生成して貼り付け

# -------------------------------------------------------------------
# 必須：初回セットアップ用キー
# -------------------------------------------------------------------
# /setup ページでの管理者アカウント作成時に使用。
# 任意の長めの文字列を設定（知っているのは森脇さんだけ、という前提）。
SETUP_KEY=hinata-setup-2024-change-me

# -------------------------------------------------------------------
# 必須：管理者メールアドレス
# -------------------------------------------------------------------
# このメールで初回ログインしたユーザーが自動的にadmin権限を付与される。
# Google OAuth と メール/パスワード認証の両方で機能。
OWNER_EMAIL=takashimoriwaki@kokoronohinata.com

# -------------------------------------------------------------------
# 必須：Google OAuth（スタッフの Google ログイン）
# -------------------------------------------------------------------
# Google Cloud Console の OAuth 2.0 Client ID
# redirect URIにはRailwayドメイン（例：https://hinata.up.railway.app/api/auth/google/callback）と、
# 本番カスタムドメイン（https://hinata.kokoronohinata.com/api/auth/google/callback）を登録しておく。
VITE_GOOGLE_OAUTH_CLIENT_ID=xxxxx-xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=xxxxx-xxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------------
# 必須：Gemini API（音声認識・AI機能）
# -------------------------------------------------------------------
# Google AI Studio で発行（https://ai.google.dev/）
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -------------------------------------------------------------------
# 必須：Google サービスアカウント（Sheets / Drive 連携）
# -------------------------------------------------------------------
# Google Cloud Console > IAM > サービスアカウント で発行したJSONキーから抽出
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@hinata-dashboard-xxxxxx.iam.gserviceaccount.com
# 秘密鍵は改行を \n でエスケープして1行にする
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...(中略)...xxx\n-----END PRIVATE KEY-----\n"

# Google Sheets API キー（スプレッドシート閲覧用）
GOOGLE_SHEETS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -------------------------------------------------------------------
# 必須：Web Push 通知（VAPID）
# -------------------------------------------------------------------
# 生成方法（ターミナルで）: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@kokoronohinata.com

# -------------------------------------------------------------------
# 任意：Google Picker API キー
# -------------------------------------------------------------------
# My Links ページで Google ドライブから直接ファイル選択する機能用
VITE_GOOGLE_PICKER_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# -------------------------------------------------------------------
# 任意：アプリタイトル・ロゴ
# -------------------------------------------------------------------
VITE_APP_TITLE=ひなた訪問看護ダッシュボード
# VITE_APP_LOGO=https://example.com/logo.png

# -------------------------------------------------------------------
# 自動：Node.js ランタイム設定
# -------------------------------------------------------------------
# Railway はこれを自動設定するので基本触らない
NODE_ENV=production
PORT=3000
